# =============================================================================
# NetLabs AI Backend — Environment Variables
# =============================================================================
# Salin file ini menjadi .env dan isi dengan konfigurasi yang sesuai:
#   cp .env.example .env
# =============================================================================

# [WAJIB] API Key Google Gemini
# Dapatkan di: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Direktori penyimpanan data ChromaDB (persistent)
CHROMA_PERSIST_DIR=./chroma_data

# Nama collection di ChromaDB
CHROMA_COLLECTION_NAME=netlabs_modul

# Port Flask
FLASK_PORT=5050

# Debug Mode (true/false) — set false di production
FLASK_DEBUG=false
