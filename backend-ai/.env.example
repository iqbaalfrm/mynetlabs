# =============================================================================
# NetLabs AI Backend — Environment Variables (TEMPLATE)
# =============================================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
# =============================================================================

# [WAJIB] API Key Google Gemini — dapatkan di https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Direktori penyimpanan data Qdrant (persistent, dibuat otomatis)
QDRANT_PERSIST_DIR=./qdrant_data

# Nama collection (tabel vektor) di Qdrant
QDRANT_COLLECTION_NAME=basis_pengetahuan

# Port Flask server
FLASK_PORT=5050

# Debug Mode (true/false) — WAJIB false di production
FLASK_DEBUG=false
